{
  "name": "sistema-gestion-lch",
  "private": true,
  "version": "2.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:infra": "docker compose up -d postgres redis minio minio-init",
    "start:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "start:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1 -Setup",
    "start:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1 -All",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:admin": "npm run dev --workspace=apps/web-admin",
    "stop:admin": "npx --yes kill-port 5173",
    "dev:public": "npm run dev --workspace=apps/web-public",
    "dev:webs": "concurrently -n admin,public -c green,blue \"npm run dev:admin\" \"npm run dev:public\"",
    "dev:all": "concurrently -n infra,api,admin,public -c yellow,magenta,green,blue \"npm run dev:infra\" \"npm run dev:api\" \"npm run dev:admin\" \"npm run dev:public\"",
    "test": "npm run test --workspaces --if-present",
    "test:deep": "npm run test:deep --workspace=apps/api && npm run test:deep --workspace=apps/web-admin",
    "test:admin": "npm run test --workspace=apps/web-admin",
    "test:public": "npm run test --workspace=apps/web-public",
    "test:api": "npm run test --workspace=apps/api",
    "build:admin": "npm run build --workspace=apps/web-admin",
    "build:public": "npm run build --workspace=apps/web-public",
    "build:api": "npm run build --workspace=apps/api",
    "deploy:prod": "docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build",
    "deploy:validate": "bash deploy/validate-env.sh",
    "deploy:smoke": "bash deploy/smoke-test.sh",
    "test:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/test-deploy-local.ps1",
    "oracle:retry": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/oracle-retry-saopaulo.ps1 -ReminderOnly -IntervalMinutes 30",
    "build:apk:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-apk-release.ps1",
    "security:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/security-audit.ps1",
    "electron:admin": "npm run electron:build --workspace=apps/web-admin",
    "electron:public": "npm run electron:build --workspace=apps/web-public",
    "cap:sync:admin": "cd apps/web-admin && npx cap sync",
    "cap:sync:public": "cd apps/web-public && npx cap sync",
    "cap:open:admin": "cd apps/web-admin && npx cap open android",
    "cap:open:public": "cd apps/web-public && npx cap open android",
    "cap:run:admin": "cd apps/web-admin && npx cap run android",
    "cap:run:public": "cd apps/web-public && npx cap run android"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "jsdom": "^29.1.1"
  },
  "overrides": {
    "multer": "2.2.0",
    "@nestjs/platform-express": {
      "multer": "2.2.0"
    },
    "lodash": "^4.17.24",
    "js-yaml": "4.2.0",
    "@nestjs/swagger": {
      "js-yaml": "4.2.0"
    },
    "file-type": "^21.3.2",
    "express": "^4.22.2",
    "qs": "^6.15.2",
    "body-parser": "^1.20.5",
    "form-data": "^4.0.6",
    "shell-quote": "^1.8.4",
    "undici": "^7.27.3",
    "tar": "^7.5.16",
    "dompurify": "^3.4.11",
    "esbuild": "^0.25.0",
    "vite": {
      "esbuild": "^0.25.0"
    },
    "glob": "^11.0.0",
    "picomatch": "^4.0.4",
    "tmp": "^0.2.6",
    "@babel/core": "^7.29.1",
    "webpack": "^5.105.0",
    "xlsx": "npm:@stackline/xlsx@^1.0.3"
  }
}
