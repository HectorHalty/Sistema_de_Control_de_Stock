# Local development environment variables
# Copy to apps/api/.env and modify as needed

# Database
DATABASE_URL=postgresql://lch:lch_dev_pass@localhost:5432/lch_stock?schema=public
DIRECT_URL=postgresql://lch:lch_dev_pass@localhost:5432/lch_stock?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=24h

# MinIO / S3-compatible storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_dev_pass
MINIO_USE_SSL=false
MINIO_BUCKET_MEDIA=lch-media
MINIO_BUCKET_SPONSORS=lch-sponsors
MINIO_BUCKET_FOOTBALL=lch-football

# API
PORT=3001
NODE_ENV=development
