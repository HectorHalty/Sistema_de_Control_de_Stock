# Copiar a .env.production y completar valores antes de desplegar.
POSTGRES_USER=lch
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=lch_stock

JWT_SECRET=change-me-generate-with-openssl-rand-base64-48
JWT_EXPIRES_IN=1h
ALLOWED_ORIGINS=https://admin.tudominio.com

REDIS_PASSWORD=change-me-redis-password

MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=change-me-minio-secret

# URL pública de la API (la usa el build del admin)
VITE_API_URL=https://api.tudominio.com

API_PORT=3001
ADMIN_PORT=8080
