# Copiar a .env.production y completar ANTES de desplegar.
#   cp .env.production.example .env.production

# Orígenes CORS: web admin DuckDNS + Capacitor APK
ADMIN_DOMAIN=lachacrafutbol.duckdns.org
API_DOMAIN=lachacra-api.duckdns.org
ALLOWED_ORIGINS=https://lachacrafutbol.duckdns.org,https://localhost,capacitor://localhost,http://localhost

# --- PostgreSQL (evitar / @ : en POSTGRES_PASSWORD — rompe DATABASE_URL) ---
POSTGRES_USER=lch
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=lch_stock

# --- Auth (generar: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))") ---
JWT_SECRET=change-me-generate-with-openssl-rand-base64-48
JWT_EXPIRES_IN=1h
# Rate limit login (se cuentan solo intentos fallidos)
AUTH_LIMIT_MAX=200
AUTH_LIMIT_WINDOW_MS=900000

# --- Redis ---
REDIS_PASSWORD=change-me-redis-password

# --- MinIO (NO usar minio_admin en producción) ---
MINIO_ACCESS_KEY=change-me-minio-user
MINIO_SECRET_KEY=change-me-minio-secret

# URL pública de la API (build del admin web y APK)
VITE_API_URL=https://lachacra-api.duckdns.org

# Puertos locales (solo localhost; Caddy expone HTTPS al exterior)
API_PORT=3001
ADMIN_PORT=8080
